<%layout("/layouts/boilerplate")%>
<h1 class="col-6 offset-3">Login for WanderLust</h1>        
<div class="row mt-3">
    <div class="col-6 offset-3">
    <form method="POST" action = "/login" novalidate class="needs-validation">       
        <div class="mb-3">
            <lable for="username" class="form-label">Username</lable>
            <input name="username" id="username" type="text" class="form-control"required/>
            <div class="valid-feedback">Looks Good!</div>
            <div class="invalid-feedback">Username should be valid</div>
        </div>

        <div class="mb-3">
            <lable for="password" class="form-label">Password</lable>
            <input name="password" id="password" type="password" class="form-control"required/>
        </div>
        <button class="btn btn-success">Login</button>
    </form>
    </div>
</div>        