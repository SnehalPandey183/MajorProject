<%layout("/layouts/boilerplate")%>
<div class="row">
    <div class="col-8 offset-2">
    <form method="POST" action = "/listings" novalidate class="needs-validation" enctype = "multipart/form-data">
        <br/><br/>
        <h3>Create new Listing</h3>
        <div class="mb-3">
            <lable for="title" class="form-label">Title</lable>
            <input name="listing[title]" placeholder="enter title" type="text" class="form-control"required/>
            <div class="valid-feedback">Looks Good!</div>
            <div class="invalid-feedback">Title should be valid</div>
        </div>
        <div class="mb-3">
        <lable for="description" class="form-label">Description</lable>
        <textarea name="listing[description]" class="form-control"required></textarea>
            <div class="valid-feedback">Looks Good!</div>
            <div class="invalid-feedback">Description should be valid</div>        
        </div>
        <div class="mb-3">
            <lable for="image" class="form-label">Image</lable>
            <input name="listing[image]" placeholder="enter image-url" type="text" class="form-control"/>            
        </div>
        <div class="mb-3">
            <lable for="image" class="form-label">Upload Listing Image</lable>
            <input name="listing[image]" type="file" class="form-control" required/>            
        </div>        
        <div class="row">
        <div class="mb-3 col-md-4">
            <lable for="price" class="form-label">Price</lable>
            <input name="listing[price]" placeholder="enter price"  class="form-control"required/>
            <div class="valid-feedback">Looks Good!</div>
            <div class="invalid-feedback">Price should be valid</div>            
        </div>
        <div class="mb-3 col-md-8">
            <lable for="country" class="form-label">Country</lable>
            <input name="listing[country]" placeholder="enter country" type="text" class="form-control"required/>
            <div class="valid-feedback">Looks Good!</div>
            <div class="invalid-feedback">Country should be valid</div>            
        </div>
        </div>
        <div class="mb-3">
            <lable for="location" class="form-label">Location</lable>
            <input name="listing[location]" placeholder="enter location" type="text" class="form-control"required/>
            <div class="valid-feedback">Looks Good!</div>
            <div class="invalid-feedback">Location should be valid</div>            
        </div>
        <br /><br />
        <button class="btn btn-dark add-btn">Add</button>
        <br/><br/><br/>
    </form>
    </div>
</div>





