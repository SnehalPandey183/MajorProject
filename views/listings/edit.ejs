<%layout("/layouts/boilerplate")%>
<div class="row">
    <div class="col-8 offset-2">
    <form method ="POST"action ="/listings/<%=listing._id%>?_method=PUT" enctype="multipart/form-data" novalidate class="needs-validation"><div class="row"></div>
        <br/><br/>
        <h3>Edit your Listing</h3>
        <div class="mb-3">
            <lable for="title" class="form-label">Title</lable>
            <input name="listing[title]" value="<%=listing.title%>"  type="text" class="form-control" required/>
            <div class="valid-feedback">Looks Good!</div>
            <div class="invalid-feedback">Title should be valid</div>            
        </div>
        <div class="mb-3">
            <label for="category" class="form-label">Category</label>
            <select name="listing[category]" id="category" class="form-control" required>
                <option value="">-- Select a Category --</option>
                <option value="Apartment" <% if(listing.category === "Apartment") { %>selected<% } %>>Apartment</option>
                <option value="House" <% if(listing.category === "House") { %>selected<% } %>>House</option>
                <option value="Villa" <% if(listing.category === "Villa") { %>selected<% } %>>Villa</option>
                <option value="Cabin" <% if(listing.category === "Cabin") { %>selected<% } %>>Cabin</option>
                <option value="Beach House" <% if(listing.category === "Beach House") { %>selected<% } %>>Beach House</option>
                <option value="Mountain Retreat" <% if(listing.category === "Mountain Retreat") { %>selected<% } %>>Mountain Retreat</option>
                <option value="Farmhouse" <% if(listing.category === "Farmhouse") { %>selected<% } %>>Farmhouse</option>
                <option value="Studio" <% if(listing.category === "Studio") { %>selected<% } %>>Studio</option>
                <option value="Condo" <% if(listing.category === "Condo") { %>selected<% } %>>Condo</option>
                <option value="Hostel" <% if(listing.category === "Hostel") { %>selected<% } %>>Hostel</option>
                <option value="Resort" <% if(listing.category === "Resort") { %>selected<% } %>>Resort</option>
                <option value="Hotel" <% if(listing.category === "Hotel") { %>selected<% } %>>Hotel</option>
                <option value="Cottage" <% if(listing.category === "Cottage") { %>selected<% } %>>Cottage</option>
                <option value="Boat" <% if(listing.category === "Boat") { %>selected<% } %>>Boat</option>
                <option value="Treehouse" <% if(listing.category === "Treehouse") { %>selected<% } %>>Treehouse</option>
            </select>
            <div class="valid-feedback">Looks Good!</div>
            <div class="invalid-feedback">Please select a category</div>
        </div>
        <div class="mb-3">
        <lable for="description" class="form-label">Description</lable>
        <textarea name="listing[description]" value="<%=listing.description%>" class="form-control" required></textarea>
            <div class="valid-feedback">Looks Good!</div>
            <div class="invalid-feedback">Description should be valid</div>        
        </div>
        <!-- <div class="mb-3">
            <lable for="image" class="form-label">Image</lable>
            <input name="listing[image]" value="<%=listing.image.url%>"  type="text" class="form-control" required/>
            <div class="valid-feedback">Looks Good!</div>
            <div class="invalid-feedback">image link should be valid</div>            
        </div> -->

        <!-- Image Section -->
        <div class="mb-3">
        <label class="form-label">Current Image</label><br>

          <!-- Show existing image -->
          <img 
            src="<%= originalImageUrl %>" 
            alt="listing_image" 
            width="250" 
            class="mb-3 rounded"
          >
          <br/>

          <!-- Upload new image -->
          <label for="image" class="form-label">Upload New Image</label>
          <input 
            type="file" 
            name="listing[image]" 
            id="image" 
            class="form-control"
          >
        </div>        
        <div class="row">
        <div class="mb-3 col-md-4">
            <lable for="price" class="form-label">Price</lable>
            <input name="listing[price]" value="<%=listing.price%>"  type="number" class="form-control" required/>
            <div class="valid-feedback">Looks Good!</div>
            <div class="invalid-feedback">Price should be valid</div>            
        </div>
        <div class="mb-3 col-md-8">
            <lable for="country" class="form-label">Country</lable>
            <input name="listing[country]" value="<%=listing.country%>"  type="text" class="form-control" required/>
            <div class="valid-feedback">Looks Good!</div>
            <div class="invalid-feedback">Country should be valid</div>            
        </div>
        </div>
        <div class="mb-3">
            <lable for="location" class="form-label">Location</lable>
            <input name="listing[location]" value="<%=listing.location%>"  type="text" class="form-control" required/>
                <div class="valid-feedback">Looks Good!</div>
            <div class="invalid-feedback">Location should be valid</div>        
        </div>
        <br /><br />
        <button class="btn btn-dark add-btn">Edit</button>
        <br/><br/><br/>
    </form>
    </div>
</div>















