<% layout("/layouts/boilerplate") %>

<style>

/* ===== PAGE BASE ===== */
body {
  background-color: #fafafa;
}

main {
  margin-top: 10px;
}

/* ===== CATEGORY BAR ===== */
.category-bar {
  position: relative;

  background: #fff;
  border-bottom: 1px solid #eee;

  padding: 12px 0;
  margin-top: 12px;
  margin-bottom: 18px;

  box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
  overflow-x: auto;
}

.category-bar::-webkit-scrollbar {
  display: none;
}

/* ===== CATEGORY CONTAINER ===== */
.category-container {
  display: flex;
  align-items: center;
  gap: 24px;
  padding: 0 20px;
  min-width: max-content;
}

/* ===== CATEGORY BUTTON ===== */
.category-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5px;

  border: none;
  background: none;
  cursor: pointer;
  text-decoration: none;

  color: #666;
  font-size: 12px;
  min-width: 70px;

  transition: all 0.2s ease;
}

.category-btn i {
  font-size: 18px;
}

.category-btn:hover {
  color: #fe424d;
  transform: translateY(-2px);
  text-decoration: none;
}

.category-btn.active {
  color: #fe424d;
  border-bottom: 2px solid #fe424d;
  padding-bottom: 6px;
}

/* ===== TAX TOGGLE ===== */
.tax-toggle {
  margin-left: auto;
  display: flex;
  align-items: center;
  padding-left: 20px;
  border-left: 1px solid #eee;
}

/* ===== LISTINGS ===== */
.listing-row {
  margin-top: 20px;
  margin-bottom: 40px;
  padding-bottom: 20px;
}

.listing-card {
  border: none;
  border-radius: 14px;
  overflow: hidden;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.listing-card:hover {
  transform: scale(1.02);
  box-shadow: 0 6px 18px rgba(0,0,0,0.1);
}

.listing-card img {
  height: 20rem;
  object-fit: cover;
}

.card-text {
  font-size: 14px;
  color: #333;
}

.tax-info {
  color: #777;
  font-size: 13px;
  display: none;
}

</style>


<!-- ===== CATEGORY BAR ===== -->
<div class="category-bar">
  <div class="category-container">

    <a href="/listings" class="category-btn <% if(selectedCategory === 'all') { %>active<% } %>">
      <i class="fa-solid fa-fire"></i>
      <span>All</span>
    </a>

    <a href="/listings?category=Apartment" class="category-btn <% if(selectedCategory === 'Apartment') { %>active<% } %>">
      <i class="fa-solid fa-building"></i>
      <span>Apartment</span>
    </a>

    <a href="/listings?category=House" class="category-btn <% if(selectedCategory === 'House') { %>active<% } %>">
      <i class="fa-solid fa-house"></i>
      <span>House</span>
    </a>

    <a href="/listings?category=Villa" class="category-btn <% if(selectedCategory === 'Villa') { %>active<% } %>">
      <i class="fa-solid fa-gopuram"></i>
      <span>Villa</span>
    </a>

    <a href="/listings?category=Cabin" class="category-btn <% if(selectedCategory === 'Cabin') { %>active<% } %>">
      <i class="fa-solid fa-tree"></i>
      <span>Cabin</span>
    </a>

    <a href="/listings?category=Beach House" class="category-btn <% if(selectedCategory === 'Beach House') { %>active<% } %>">
      <i class="fa-solid fa-water"></i>
      <span>Beach</span>
    </a>

    <a href="/listings?category=Mountain Retreat" class="category-btn <% if(selectedCategory === 'Mountain Retreat') { %>active<% } %>">
      <i class="fa-solid fa-mountain"></i>
      <span>Mountains</span>
    </a>

    <a href="/listings?category=Farmhouse" class="category-btn <% if(selectedCategory === 'Farmhouse') { %>active<% } %>">
      <i class="fa-solid fa-tractor"></i>
      <span>Farms</span>
    </a>

    <a href="/listings?category=Studio" class="category-btn <% if(selectedCategory === 'Studio') { %>active<% } %>">
      <i class="fa-solid fa-palette"></i>
      <span>Studio</span>
    </a>

    <a href="/listings?category=Resort" class="category-btn <% if(selectedCategory === 'Resort') { %>active<% } %>">
      <i class="fa-solid fa-umbrellas"></i>
      <span>Resort</span>
    </a>

    <a href="/listings?category=Boat" class="category-btn <% if(selectedCategory === 'Boat') { %>active<% } %>">
      <i class="fa-solid fa-sailboat"></i>
      <span>Boat</span>
    </a>

    <!-- TAX TOGGLE -->
    <div class="tax-toggle">
      <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" id="taxSwitch">
        <label class="form-check-label">Show tax</label>
      </div>
    </div>

  </div>
</div>


<!-- ===== LISTINGS ===== -->
<div class="row listing-row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

<% for (let listing of allListings) { %>

  <div class="col">
    <a href="/listings/<%= listing._id %>" class="text-decoration-none">

      <div class="card listing-card h-100">
        <img src="<%= listing.image.url %>" class="card-img-top">

        <div class="card-body">
          <p class="card-text mb-1">
            <b><%= listing.title %></b>
          </p>
          <p class="card-text mb-2">
            <span class="badge bg-danger"><%= listing.category %></span>
          </p>
          <p class="card-text">
            ₹<%= listing.price.toLocaleString("en-IN") %> / night
            <span class="tax-info"> +18% GST</span>
          </p>
        </div>
      </div>

    </a>
  </div>

<% } %>

</div>


<script>
// TAX TOGGLE
document.getElementById("taxSwitch").addEventListener("change", function () {
  document.querySelectorAll(".tax-info").forEach(el => {
    el.style.display = this.checked ? "inline" : "none";
  });
});
</script>