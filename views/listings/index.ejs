 <% layout("/layouts/boilerplate") %>

<style>
/* CATEGORY BAR */
.category-bar {
  position: sticky;
  top: 66px;
  z-index: 998;
  background: #fff;
  border-bottom: 1px solid #eee;
  padding: 10px 0;
  overflow-x: auto;
}

.category-bar::-webkit-scrollbar {
  display: none;
}

.category-container {
  display: flex;
  align-items: center;
  gap: 18px;
  padding: 0 16px;
}

/* CATEGORY BUTTON */
.category-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  border: none;
  background: none;
  cursor: pointer;
  color: #666;
  font-size: 12px;
  min-width: 70px;
  transition: all 0.2s ease;
}

.category-btn i {
  font-size: 18px;
}

.category-btn:hover {
  color: #fe424d;
  transform: translateY(-2px);
}

.category-btn.active {
  color: #fe424d;
  border-bottom: 2px solid #fe424d;
}

/* TAX TOGGLE */
.tax-toggle {
  margin-left: auto;
  display: flex;
  align-items: center;
}

/* CARDS */
.listing-card img {
  border-radius: 12px;
  object-fit: cover;
}
</style>

<!-- CATEGORY BAR -->
<div class="category-bar">
  <div class="category-container">

    <button class="category-btn active"><i class="fa-solid fa-fire"></i><span>Trending</span></button>
    <button class="category-btn"><i class="fa-solid fa-bed"></i><span>Rooms</span></button>
    <button class="category-btn"><i class="fa-solid fa-landmark"></i><span>Cities</span></button>
    <button class="category-btn"><i class="fa-solid fa-mountain"></i><span>Mountains</span></button>
    <button class="category-btn"><i class="fa-solid fa-water"></i><span>Pools</span></button>
    <button class="category-btn"><i class="fa-solid fa-chess-rook"></i><span>Castles</span></button>
    <button class="category-btn"><i class="fa-solid fa-tractor"></i><span>Farms</span></button>
    <button class="category-btn"><i class="fa-solid fa-campground"></i><span>Camping</span></button>

    <!-- TAX TOGGLE -->
    <div class="tax-toggle">
      <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" id="taxSwitch">
        <label class="form-check-label">Show tax</label>
      </div>
    </div>

  </div>
</div>

<!-- LISTINGS -->
<div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">

<% for (let listing of allListings) { %>
  <div class="col">
    <a href="/listings/<%= listing._id %>" class="listing-link">
      <div class="card h-100 listing-card">
        <img src="<%= listing.image.url %>" class="card-img-top" style="height: 20rem">

        <div class="card-body">
          <p class="card-text">
            <b><%= listing.title %></b><br>
            ₹<%= listing.price.toLocaleString("en-IN") %> / night
            <span class="tax-info" style="display:none;"> +18% GST</span>
          </p>
        </div>
      </div>
    </a>
  </div>
<% } %>

</div>

<script>
// ACTIVE CATEGORY
document.querySelectorAll(".category-btn").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".category-btn").forEach(b => b.classList.remove("active"));
    btn.classList.add("active");
  });
});

// TAX TOGGLE
document.getElementById("taxSwitch").addEventListener("change", function () {
  document.querySelectorAll(".tax-info").forEach(el => {
    el.style.display = this.checked ? "inline" : "none";
  });
});
</script>