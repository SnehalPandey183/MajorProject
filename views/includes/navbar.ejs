<style>
  /* Navbar Styles */
  .navbar-brand i {
    font-size: 1.5rem;
    color: #fe424d;
  }

  .navbar-brand:hover i {
    color: #ff5566;
    transition: color 0.3s ease;
  }

  /* Search Bar Styles */
  .search-form {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .search-inp {
    border-radius: 25px;
    padding: 0.5rem 1rem;
    font-size: 0.95rem;
    border: 1px solid #ddd;
    min-width: 150px;
    flex: 1;
  }

  .search-inp:focus {
    outline: none;
    border-color: #fe424d;
    box-shadow: 0 0 0 0.2rem rgba(254, 66, 77, 0.25);
  }

  .btn-search {
    background-color: #fe424d;
    color: #fff;
    border-radius: 25px;
    padding: 0.5rem 1.5rem;
    border: none;
    font-weight: 500;
    white-space: nowrap;
  }

  .btn-search:hover {
    background-color: #ff5566;
    color: #fff;
  }

  .btn-search i {
    margin-right: 0.4rem;
  }

  /* Category Filter Bar */
  .category-bar {
    background-color: #fff;
    border-bottom: 1px solid #e5e5e5;
    padding: 0.75rem 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .category-container {
    display: flex;
    gap: 1rem;
    padding: 0 1rem;
    min-width: min-content;
  }

  .category-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border: 2px solid transparent;
    border-radius: 20px;
    background-color: transparent;
    color: #333;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .category-btn:hover {
    border-color: #fe424d;
    color: #fe424d;
  }

  .category-btn.active {
    border-color: #fe424d;
    color: #fe424d;
  }

  .category-btn i {
    font-size: 1.5rem;
  }

  /* Tax Toggle */
  .tax-toggle-container {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-left: 1px solid #e5e5e5;
  }

  .tax-toggle-container label {
    margin: 0;
    font-size: 0.85rem;
    font-weight: 500;
    cursor: pointer;
  }

  .toggle-checkbox {
    width: 2rem;
    height: 1rem;
    cursor: pointer;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .search-form {
      width: 100%;
      margin-top: 0.5rem;
    }

    .search-inp {
      min-width: 120px;
      font-size: 0.9rem;
    }

    .btn-search {
      padding: 0.5rem 1rem;
      font-size: 0.9rem;
    }

    .category-container {
      padding: 0 0.5rem;
      gap: 0.75rem;
    }

    .category-btn {
      padding: 0.6rem 0.8rem;
      font-size: 0.75rem;
      gap: 0.3rem;
    }

    .category-btn i {
      font-size: 1.2rem;
    }

    .tax-toggle-container {
      padding: 0.5rem 0.75rem;
      gap: 0.3rem;
    }

    .tax-toggle-container label {
      font-size: 0.75rem;
    }
  }

  @media (max-width: 576px) {
    .search-inp {
      min-width: 100px;
      padding: 0.4rem 0.8rem;
    }

    .btn-search {
      padding: 0.4rem 0.8rem;
      font-size: 0.85rem;
    }

    .btn-search span {
      display: none;
    }

    .navbar-nav {
      gap: 0.25rem;
    }
  }
</style>

<!-- Main Navbar -->
<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-compass"></i>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav flex-grow-1">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <!-- Search Bar -->
      <form class="navbar-nav search-form me-3">
        <input class="search-inp" type="search" placeholder="Search destinations..." aria-label="Search Destinations">
        <button class="btn btn-search" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i>
          <span>Search</span>
        </button>
      </form>

      <!-- User Links -->
      <div class="navbar-nav">
        <a class="nav-link" href="/listings/new">Add Listing</a>
        <% if(!currUser) { %>
        <a class="nav-link" href="/signup"><b>SignUp</b></a>
        <a class="nav-link" href="/login"><b>Login</b></a>
        <% } %>
        <% if(currUser) { %>
        <a class="nav-link" href="/logout">Logout</a>
        <% } %>
      </div>
    </div>
  </div>
</nav>

<!-- Category Filter Bar with Tax Toggle -->
<div class="category-bar">
  <div class="container-fluid">
    <div class="d-flex align-items-center justify-content-between">
      <!-- Categories Container -->
      <div class="category-container flex-grow-1">
        <button class="category-btn" data-category="trending">
          <i class="fa-solid fa-fire"></i>
          <span>Trending</span>
        </button>
        <button class="category-btn" data-category="rooms">
          <i class="fa-solid fa-door-open"></i>
          <span>Rooms</span>
        </button>
        <button class="category-btn" data-category="iconic">
          <i class="fa-solid fa-landmark"></i>
          <span>Iconic Cities</span>
        </button>
        <button class="category-btn" data-category="mountains">
          <i class="fa-solid fa-mountain"></i>
          <span>Mountains</span>
        </button>
        <button class="category-btn" data-category="pools">
          <i class="fa-solid fa-water"></i>
          <span>Amazing Pools</span>
        </button>
        <button class="category-btn" data-category="castles">
          <i class="fa-solid fa-chess-rook"></i>
          <span>Castles</span>
        </button>
        <button class="category-btn" data-category="farms">
          <i class="fa-solid fa-tractor"></i>
          <span>Farms</span>
        </button>
        <button class="category-btn" data-category="camping">
          <i class="fa-solid fa-campground"></i>
          <span>Camping</span>
        </button>
        <button class="category-btn" data-category="arctic">
          <i class="fa-solid fa-snowflake"></i>
          <span>Arctic</span>
        </button>
        <button class="category-btn" data-category="island">
          <i class="fa-solid fa-island"></i>
          <span>Island</span>
        </button>
      </div>

      <!-- Tax Toggle -->
      <div class="tax-toggle-container">
        <label for="taxToggle">Show total with taxes</label>
        <input type="checkbox" id="taxToggle" class="toggle-checkbox">
      </div>
    </div>
  </div>
</div>

<script>
  // Category filter functionality
  document.querySelectorAll('.category-btn').forEach(btn => {
    btn.addEventListener('click', function() {
      document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      // Add your filter logic here
      console.log('Filter by:', this.dataset.category);
    });
  });

  // Tax toggle functionality
  document.getElementById('taxToggle').addEventListener('change', function() {
    // Add your tax display logic here
    console.log('Show tax:', this.checked);
  });
</script>


