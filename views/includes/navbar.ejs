<style>
  /* Navbar Styles */
  .navbar-brand i {
    font-size: 1.5rem;
    color: #fe424d;
  }

  .navbar-brand:hover i {
    color: #ff5566;
    transition: color 0.3s ease;
  }

  /* Search Bar Styles */
  .search-form {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .search-inp {
    border-radius: 25px;
    padding: 0.5rem 1rem;
    font-size: 0.95rem;
    border: 1px solid #ddd;
    width: 220px;          /* ✅ Fixed width — no more stretching */
  }

  .search-inp:focus {
    outline: none;
    border-color: #fe424d;
    box-shadow: 0 0 0 0.2rem rgba(254, 66, 77, 0.25);
  }

  .btn-search {
    background-color: #fe424d;
    color: #fff;
    border-radius: 25px;
    padding: 0.5rem 1.2rem;
    border: none;
    font-weight: 500;
    white-space: nowrap;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .btn-search:hover {
    background-color: #ff5566;
    color: #fff;
  }

  /* Category Filter Bar */
  .category-bar {
    background-color: #fff;
    border-bottom: 1px solid #e5e5e5;
    padding: 0.5rem 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* hide scrollbar Firefox */
  }

  .category-bar::-webkit-scrollbar {
    display: none; /* hide scrollbar Chrome */
  }

  .category-wrapper {
    display: flex;
    align-items: center;
    min-width: max-content;
    padding: 0 1rem;
    gap: 0.25rem;
  }

  .category-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.3rem;
    padding: 0.5rem 1rem;
    border: 2px solid transparent;
    border-radius: 12px;
    background-color: transparent;
    color: #717171;
    font-size: 0.78rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .category-btn:hover {
    border-color: #ddd;
    color: #222;
  }

  .category-btn.active {
    border-color: #222;
    color: #222;
  }

  .category-btn i {
    font-size: 1.4rem;
  }

  /* Tax Toggle — pinned to right, separated by border */
  .tax-toggle-container {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem 0.5rem 1.25rem;
    border-left: 1px solid #e5e5e5;
    flex-shrink: 0;
    background: #fff;
    position: sticky;
    right: 0;
  }

  .tax-toggle-container label {
    margin: 0;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    color: #222;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .search-form {
      width: 100%;
      margin-top: 0.5rem;
    }

    .search-inp {
      width: 100%;        /* full width only inside collapsed menu */
      flex: 1;
    }

    .btn-search span {
      display: inline;
    }
  }

  @media (max-width: 576px) {
    .btn-search span {
      display: none;   /* icon only on very small screens */
    }
  }
</style>

<!-- ✅ Main Navbar -->
<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-compass"></i>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
      data-bs-target="#navbarNavAltMarkup" aria-controls="navbarNavAltMarkup"
      aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <!-- Explore link -->
      <div class="navbar-nav flex-grow-1">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <!-- ✅ FIX: changed from navbar-nav to d-flex so search stays inline -->
      <form class="d-flex search-form me-3" action="/listings" method="GET">
        <input class="search-inp form-control" type="search"
          name="search" placeholder="Search destinations..."
          aria-label="Search Destinations">
        <button class="btn btn-search" type="submit">
          <i class="fa-solid fa-magnifying-glass"></i>
          <span>Search</span>
        </button>
      </form>

      <!-- User Links -->
      <div class="navbar-nav">
        <a class="nav-link" href="/listings/new">Add Listing</a>
        <% if(!currUser) { %>
          <a class="nav-link" href="/signup"><b>SignUp</b></a>
          <a class="nav-link" href="/login"><b>Login</b></a>
        <% } %>
        <% if(currUser) { %>
          <a class="nav-link" href="/logout">Logout</a>
        <% } %>
      </div>
    </div>
  </div>
</nav>

<!-- ✅ Category Filter Bar — outside navbar, so it never overlaps -->
<div class="category-bar">
  <div class="d-flex align-items-center">
    <div class="category-wrapper flex-grow-1">
      <button class="category-btn" data-category="trending">
        <i class="fa-solid fa-fire"></i>
        <span>Trending</span>
      </button>
      <button class="category-btn" data-category="rooms">
        <i class="fa-solid fa-door-open"></i>
        <span>Rooms</span>
      </button>
      <button class="category-btn" data-category="iconic">
        <i class="fa-solid fa-city"></i>
        <span>Iconic Cities</span>
      </button>
      <button class="category-btn" data-category="mountains">
        <i class="fa-solid fa-mountain"></i>
        <span>Mountains</span>
      </button>
      <button class="category-btn" data-category="pools">
        <i class="fa-solid fa-swimming-pool"></i>
        <span>Amazing Pools</span>
      </button>
      <button class="category-btn" data-category="castles">
        <i class="fa-solid fa-chess-rook"></i>
        <span>Castles</span>
      </button>
      <button class="category-btn" data-category="farms">
        <i class="fa-solid fa-tractor"></i>
        <span>Farms</span>
      </button>
      <button class="category-btn" data-category="camping">
        <i class="fa-solid fa-campground"></i>
        <span>Camping</span>
      </button>
      <button class="category-btn" data-category="arctic">
        <i class="fa-solid fa-snowflake"></i>
        <span>Arctic</span>
      </button>
      <!-- ✅ FIX: fa-island doesn't exist — replaced with fa-umbrella-beach -->
      <button class="category-btn" data-category="island">
        <i class="fa-solid fa-umbrella-beach"></i>
        <span>Island</span>
      </button>
    </div>

    <!-- Tax Toggle pinned to right -->
    <div class="tax-toggle-container">
      <label for="taxToggle">Display total after tax</label>
      <div class="form-check form-switch mb-0">
        <input class="form-check-input" type="checkbox" id="taxToggle" role="switch">
      </div>
    </div>
  </div>
</div>

<script>
  // Category active state
  document.querySelectorAll('.category-btn').forEach(btn => {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
      const category = this.dataset.category;
      // Filter listings — update URL param and reload or use AJAX
      const url = new URL(window.location.href);
      url.searchParams.set('category', category);
      window.location.href = url.toString();
    });
  });

  // Mark active category on page load from URL
  const params = new URLSearchParams(window.location.search);
  const activeCategory = params.get('category');
  if (activeCategory) {
    const activeBtn = document.querySelector(`.category-btn[data-category="${activeCategory}"]`);
    if (activeBtn) activeBtn.classList.add('active');
  }

  // Tax toggle
  document.getElementById('taxToggle').addEventListener('change', function () {
    console.log('Show tax:', this.checked);
    // Add your price display logic here
  });
</script>